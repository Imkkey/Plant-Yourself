  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: de8952b5a63ea104dbfc2c06ad19fdea, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NewsUI
  listPanel: {fileID: 2062353780}
  articlePanel: {fileID: 1425838298}
  listContent: {fileID: 1625925494}
  newsItemPrefab: {fileID: 3738593086869018301, guid: dbb00986c450f744185f0ebbf101681e, type: 3}
  articleTitleText: {fileID: 471020873}
  articleContentText: {fileID: 806528174}
  articleScrollView: {fileID: 1802545333}
  btnBack: {fileID: 1881825417}
  newsList:
  - title: "\u041E\u0431\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435 Plant Yourself
      - 28 \u0444\u0435\u0432\u0440\u0430\u043B\u044F 2026"
    content: "[ \u0413\u0415\u0419\u041C\u041F\u041B\u0415\u0419 ]\r\n\u0421\u0442\u0435\u0431\u043B\u0438
      \u0434\u0443\u0431\u0430 \u0438 \u043B\u043E\u0437\u044B \u0442\u0435\u043F\u0435\u0440\u044C
      \u0441\u043E\u0431\u043B\u044E\u0434\u0430\u044E\u0442 \u0437\u0430\u043A\u043E\u043D\u044B
      \u0444\u0438\u0437\u0438\u043A\u0438: \u043E\u043D\u0438 \u0431\u043E\u043B\u044C\u0448\u0435
      \u043D\u0435 \u043C\u043E\u0433\u0443\u0442 \u043F\u0440\u043E\u0440\u0430\u0441\u0442\u0430\u0442\u044C
      \u0441\u043A\u0432\u043E\u0437\u044C \u0441\u0442\u0435\u043D\u044B \u0438
      \u0442\u0435\u043A\u0441\u0442\u0443\u0440\u044B \u043E\u043A\u0440\u0443\u0436\u0435\u043D\u0438\u044F.\r\n\u0420\u0430\u0441\u0442\u0435\u043D\u0438\u044F
      \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435 \u043F\u0440\u043E\u0431\u0438\u0432\u0430\u044E\u0442
      \u0431\u0435\u0442\u043E\u043D: \u0442\u0435\u043F\u0435\u0440\u044C \u0432\u044B\u0441\u0430\u0436\u0438\u0432\u0430\u0442\u044C\u0441\u044F
      \u0438 \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u0442\u044C\u0441\u044F
      \u0432 \u0440\u043E\u043C\u0430\u0448\u043A\u0443 \u043C\u043E\u0436\u043D\u043E
      \u0442\u043E\u043B\u044C\u043A\u043E \u043D\u0430 \u043F\u043E\u0434\u0445\u043E\u0434\u044F\u0449\u0438\u0445
      \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044F\u0445 (\u0437\u0435\u043C\u043B\u044F,
      \u0442\u0440\u0430\u0432\u0430, \u043F\u043E\u0447\u0432\u0430).\r\n\u0418\u0441\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0430
      \u043E\u0448\u0438\u0431\u043A\u0430, \u0438\u0437-\u0437\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
      \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430 \u043F\u043E\u0441\u0430\u0434\u043A\u0438
      \u043C\u043E\u0433\u043B\u0430 \u043F\u0440\u0435\u0440\u044B\u0432\u0430\u0442\u044C\u0441\u044F
      \u0438\u043B\u0438 \u0431\u0430\u0433\u043E\u0432\u0430\u0442\u044C \u0438\u0437-\u0437\u0430
      \u0441\u0442\u043E\u043B\u043A\u043D\u043E\u0432\u0435\u043D\u0438\u044F \u0438\u0433\u0440\u043E\u043A\u0430
      \u0441 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438
      \u0445\u0438\u0442\u0431\u043E\u043A\u0441\u0430\u043C\u0438.\n\r\n[ \u0418\u041D\u0422\u0415\u0420\u0424\u0415\u0419\u0421
      \u0418 \u041C\u0415\u041D\u042E ]\r\n\u0412 \u0438\u0433\u0440\u0443 \u0434\u043E\u0431\u0430\u0432\u043B\u0435\u043D\u043E
      \u043D\u0435\u043F\u043E\u043B\u043D\u043E\u0446\u0435\u043D\u043D\u043E\u0435
      \u0413\u043B\u0430\u0432\u043D\u043E\u0435 \u041C\u0435\u043D\u044E.\n\r\n[
      \u0421\u0415\u0422\u042C \u0418 \u0420\u0410\u0417\u041D\u041E\u0415 ]\r\n\u0414\u043E\u0431\u0430\u0432\u043B\u0435\u043D\u0430
      \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0431\u0430\u0437\u0430
      \u0434\u043B\u044F \u043F\u0440\u0430\u0432 \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044F
      \u043B\u043E\u0431\u0431\u0438 (\u0425\u043E\u0441\u0442\u0430). \u041F\u043E\u044F\u0432\u0438\u043B\u0430\u0441\u044C
      \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u0438\u0441\u043A\u043B\u044E\u0447\u0430\u0442\u044C
      \u0438\u0433\u0440\u043E\u043A\u043E\u0432 \u0438\u0437 \u043B\u043E\u0431\u0431\u0438.\n\u041E\u043F\u0442\u0438\u043C\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u0430
      \u0441\u0435\u0442\u0435\u0432\u0430\u044F \u0438\u043D\u0442\u0435\u0440\u043F\u043E\u043B\u044F\u0446\u0438\u044F
      \u043F\u0440\u0438 \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0430\u0445 \u043C\u0435\u0436\u0434\u0443
      \u0441\u0446\u0435\u043D\u0430\u043C\u0438 \u043C\u0435\u043D\u044E \u0438
      \u0438\u0433\u0440\u044B."
